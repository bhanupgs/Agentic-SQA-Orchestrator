# LLM Configuration
# Replace with your actual API key. Do not commit your real .env file!
LLM_API_KEY=your_openai_or_gemini_api_key_here

# Framework Settings
# Options: gpt-4-turbo-preview, gemini-pro, etc.
MODEL_NAME=gpt-4-turbo-preview

# Orchestration Settings (Optional)
# If using a local n8n instance
N8N_WEBHOOK_URL=http://localhost:5678/webhook/sqa-orchestrator
